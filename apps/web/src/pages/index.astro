---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import Visualization from "../components/Visualization.tsx";
---

<Layout>
  <!-- ARCADE CABINET WORKSPACE -->
  <main
    class="mx-auto flex w-full max-w-[1200px] flex-1 flex-col justify-center gap-12 p-10 max-[640px]:px-4 max-[640px]:py-8"
  >
    <!-- TOP ROW: HERO INTRODUCTION & VISUALIZATION -->
    <section
      class="grid w-full grid-cols-[1.1fr_1fr] items-center gap-10 max-[950px]:grid-cols-1 max-[950px]:gap-[30px]"
    >
      <!-- HERO TEXT & BUTTONS -->
      <div class="flex flex-col gap-7">
        <div>
          <h1
            class="retro-reveal font-press sm:text-retro-h1 text-retro-fg mb-[14px] whitespace-nowrap text-[calc(8.5vw-4px)] leading-[1.4] tracking-[-1px]"
            data-stripes="4"
            data-color="stripes"
            data-delay="0.1"
          >
            STOP HOGGING <br />
            THE <span class="text-retro-orange">TOKENS</span>
          </h1>
          <p
            class="retro-reveal font-vt text-retro-body mt-3 w-fit leading-[1.1] text-[#ccc]"
            data-stripes="3"
            data-color="bg"
            data-direction="down"
            data-delay="0.4"
          >
            ccshare is a cli tool that allows people sharing the same claude subscription to more
            fairly split usage on both 5-hour and weekly windows.
          </p>
        </div>

        <!-- PLAY BUTTONS -->
        <div
          class="mt-2 flex flex-wrap gap-4 max-[640px]:w-full max-[640px]:flex-col max-[640px]:gap-3"
        >
          <div
            class="retro-reveal max-[640px]:w-full"
            data-stripes="2"
            data-color="bg"
            data-delay="0.7"
          >
            <Button
              variant="primary"
              href="/docs"
              class="max-[640px]:block max-[640px]:w-full max-[640px]:text-center"
              >QUICK START</Button
            >
          </div>
          <div
            class="retro-reveal max-[640px]:w-full"
            data-stripes="2"
            data-color="bg"
            data-delay="0.9"
          >
            <Button
              variant="outline"
              href="https://github.com/hexxt-git/ccshare"
              class="max-[640px]:block max-[640px]:w-full max-[640px]:text-center"
              >VIEW GITHUB</Button
            >
          </div>
        </div>
      </div>

      <!-- VISUALIZATION -->
      <Visualization client:visible />
    </section>

    <!-- BOTTOM ROW: 3 FEATURE CARDS -->
    <section aria-label="Key Features">
      <ul class="grid w-full grid-cols-3 gap-5 max-[950px]:grid-cols-1 max-[950px]:gap-4">
        <li>
          <article
            class="feature-reveal border-retro-border bg-retro-card flex h-full flex-col gap-2 border-2 px-5 py-4 opacity-0"
          >
            <h2 class="font-press text-retro-card-title text-retro-orange leading-[1.4]">
              EVERYONE GETS A FAIR SLICE
            </h2>
            <p class="text-retro-card-body leading-[1.05] text-[#999]">
              You don't need to manually coordinate who gets to prompt next. Simply use Claude as
              you normally would, and ccshare automatically paces the team's requests.
            </p>
          </article>
        </li>

        <li>
          <article
            class="feature-reveal border-retro-border bg-retro-card flex h-full flex-col gap-2 border-2 px-5 py-4 opacity-0"
          >
            <h2 class="font-press text-retro-card-title text-retro-yellow leading-[1.4]">
              USAGE GETS MAXIMIZED
            </h2>
            <p class="text-retro-card-body leading-[1.05] text-[#999]">
              in the case one or more team members are completely inactive. their usage gets split
              1-hour before the window closes
            </p>
          </article>
        </li>

        <li>
          <article
            class="feature-reveal border-retro-border bg-retro-card flex h-full flex-col gap-2 border-2 px-5 py-4 opacity-0"
          >
            <h2 class="font-press text-retro-card-title text-retro-green leading-[1.4]">
              SIMPLE CLI
            </h2>
            <ul class="text-retro-card-body list-disc leading-[1.05] text-[#999] [&>li]:ms-4">
              <li>get it up in 5 minutes and never have to worry about it</li>
              <li>coordinated through any cloud database or server</li>
              <li>view detailed weekly/daily reports with cost estimate metrics</li>
            </ul>
          </article>
        </li>
      </ul>
    </section>
  </main>
</Layout>

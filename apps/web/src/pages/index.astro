---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import Visualization from "../components/Visualization.astro";
---

<Layout title="ccshare">
  <!-- ARCADE CABINET WORKSPACE -->
  <main
    class="mx-auto flex w-full max-w-[1200px] flex-1 flex-col justify-center gap-12 p-10 max-[640px]:px-4 max-[640px]:py-8"
  >
    <!-- TOP ROW: HERO INTRODUCTION & VISUALIZATION -->
    <section
      class="grid w-full grid-cols-[1.1fr_1fr] items-center gap-10 max-[950px]:grid-cols-1 max-[950px]:gap-[30px]"
    >
      <!-- HERO TEXT & BUTTONS -->
      <div class="flex flex-col gap-7">
        <div>
          <h1
            class="retro-reveal font-press text-retro-h1 text-retro-fg mb-[14px] leading-[1.4] tracking-[-1px]"
            data-stripes="4"
            data-color="stripes"
            data-delay="0.1"
          >
            CLAUDE SUBSCRIPTION <br /><span class="text-retro-orange">FAIR SHARING</span>
          </h1>
          <p
            class="retro-reveal font-vt text-retro-body mt-3 w-fit leading-[1.1] text-[#ccc]"
            data-stripes="3"
            data-color="bg"
            data-delay="0.4"
          >
            ccshare is a CLI tool for claude code subscription sharing with fair usage limits for
            teams.
          </p>
        </div>

        <!-- PLAY BUTTONS -->
        <div
          class="mt-2 flex flex-wrap gap-4 max-[640px]:w-full max-[640px]:flex-col max-[640px]:gap-3"
        >
          <div
            class="retro-reveal max-[640px]:w-full"
            data-stripes="2"
            data-color="bg"
            data-delay="0.7"
          >
            <Button
              variant="primary"
              href="/docs"
              class="max-[640px]:block max-[640px]:w-full max-[640px]:text-center"
              >GET STARTED</Button
            >
          </div>
          <div
            class="retro-reveal max-[640px]:w-full"
            data-stripes="2"
            data-color="bg"
            data-delay="0.9"
          >
            <Button
              variant="outline"
              href="https://github.com/hexxt-git/ccshare"
              class="max-[640px]:block max-[640px]:w-full max-[640px]:text-center"
              >VIEW GITHUB</Button
            >
          </div>
        </div>
      </div>

      <!-- VISUALIZATION -->
      <Visualization />
    </section>

    <!-- BOTTOM ROW: 3 FEATURE CARDS -->
    <section aria-label="Key Features">
      <ul class="grid w-full grid-cols-3 gap-5 max-[950px]:grid-cols-1 max-[950px]:gap-4">
        <li>
          <article
            class="retro-reveal border-retro-border bg-retro-card flex h-full flex-col gap-2 border-2 px-5 py-4"
            data-stripes="6"
            data-color="bg"
            data-direction="right"
            data-delay="0.2"
          >
            <h2
              class="font-press text-retro-card-title text-retro-orange leading-[1.4] tracking-[0.5px]"
            >
              1. 5-HOUR USAGE SMOOTHING
            </h2>
            <p class="text-retro-card-body leading-[1.05] text-[#999]">
              Monitors active prompt volumes in rolling 5-hour slots. If a user exceeds their fair
              share, ccshare automatically queues requests to guarantee equal access.
            </p>
          </article>
        </li>

        <li>
          <article
            class="retro-reveal border-retro-border bg-retro-card flex h-full flex-col gap-2 border-2 px-5 py-4"
            data-stripes="6"
            data-color="bg"
            data-direction="left"
            data-delay="0.4"
          >
            <h2
              class="font-press text-retro-card-title text-retro-yellow leading-[1.4] tracking-[0.5px]"
            >
              2. WEEKLY QUOTA CAPPING
            </h2>
            <p class="text-retro-card-body leading-[1.05] text-[#999]">
              Tracks total tokens spent throughout the week, helping teams stay within boundaries
              and avoid subscription suspensions or service lockouts.
            </p>
          </article>
        </li>

        <li>
          <article
            class="retro-reveal border-retro-border bg-retro-card flex h-full flex-col gap-2 border-2 px-5 py-4"
            data-stripes="6"
            data-color="bg"
            data-direction="right"
            data-delay="0.6"
          >
            <h2
              class="font-press text-retro-card-title text-retro-green leading-[1.4] tracking-[0.5px]"
            >
              3. TIERED CAPACITY PROXYING
            </h2>
            <p class="text-retro-card-body leading-[1.05] text-[#999]">
              Optimizes throughput allocations depending on whether you share a Pro ($20/mo), Team
              ($100/mo), or custom Enterprise ($200/mo) tier subscription.
            </p>
          </article>
        </li>
      </ul>
    </section>
  </main>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import ClawdUser from "../components/ClawdUser.astro";
---

<Layout title="ccshare">
  <!-- ARCADE CABINET WORKSPACE -->
  <main
    class="mx-auto flex w-full max-w-[1200px] flex-1 flex-col justify-center gap-12 p-10 max-[640px]:px-4 max-[640px]:py-8"
  >
    <!-- TOP ROW: HERO INTRODUCTION & VISUALIZATION -->
    <div
      class="grid w-full grid-cols-[1.1fr_1fr] items-center gap-10 max-[950px]:grid-cols-1 max-[950px]:gap-[30px]"
    >
      <!-- HERO TEXT & BUTTONS -->
      <div class="flex flex-col gap-7">
        <div>
          <h1
            class="font-press text-retro-h1 text-retro-fg mb-[14px] leading-[1.2] tracking-[-1px]"
          >
            CLAUDE SUBSCRIPTION <br /><span class="text-retro-orange">FAIR SHARING</span>
          </h1>
          <p class="font-vt text-retro-body mt-3 leading-[1.4] text-[#ccc]">
            ccshare is a CLI tool for claude code subscription sharing with fair usage limits for
            teams.
          </p>
        </div>

        <!-- PLAY BUTTONS -->
        <div class="mt-2 flex flex-wrap gap-4">
          <Button variant="primary" href="#">START SESSION</Button>
          <Button variant="outline" href="#">WATCH TUTORIAL</Button>
        </div>
      </div>

      <!-- VISUALIZATION -->
      <div
        class="relative flex h-[340px] w-full items-center justify-center overflow-visible max-[640px]:h-[200px] max-[480px]:h-[170px]"
      >
        <div
          class="relative h-[340px] w-[640px] shrink-0 origin-center scale-90 overflow-visible max-[640px]:scale-[0.55] max-[480px]:scale-[0.45] max-[380px]:scale-[0.4]"
        >
          <!-- MONITOR -->
          <div class="absolute left-[180px] top-10 w-[280px]">
            <img
              src="/desktop.png"
              alt="monitor"
              class="block w-full opacity-90 [image-rendering:pixelated]"
            />
            <div
              class="absolute left-[58px] top-[63px] flex h-[40%] w-[40%] items-center justify-center overflow-hidden"
            >
              <img
                src="/claude.png"
                alt="Claude"
                class="animate-spin-slow h-auto w-full opacity-70 [image-rendering:pixelated]"
              />
            </div>
          </div>

          <!-- L1 -->
          <ClawdUser
            name="user_1"
            userNum={1}
            class="left-[30px] top-[10px]"
            animationClass="animate-float-a"
          />

          <!-- L2 -->
          <ClawdUser
            name="user_3"
            userNum={3}
            class="left-[0px] top-[120px]"
            animationClass="animate-float-b"
          />

          <!-- L3 -->
          <ClawdUser
            name="user_5"
            userNum={5}
            class="left-[30px] top-[230px]"
            animationClass="animate-float-a-slow"
          />

          <!-- R1 -->
          <ClawdUser
            name="user_2"
            userNum={2}
            class="left-[510px] top-[10px]"
            animationClass="animate-float-b-fast"
            flip
          />

          <!-- R2 -->
          <ClawdUser
            name="user_4"
            userNum={4}
            class="left-[540px] top-[120px]"
            animationClass="animate-float-a-mid"
            flip
          />

          <!-- R3 -->
          <ClawdUser
            name="user_6"
            userNum={6}
            class="left-[510px] top-[230px]"
            animationClass="animate-float-b-mid"
            flip
          />
        </div>
      </div>
    </div>

    <!-- BOTTOM ROW: 3 FEATURE CARDS -->
    <div class="mt-5 grid w-full grid-cols-3 gap-5 max-[950px]:grid-cols-1 max-[950px]:gap-4">
      <div class="border-retro-border bg-retro-card flex flex-col gap-2 border-2 px-5 py-4">
        <h3
          class="font-press text-retro-card-title text-retro-feat-1 leading-[1.4] tracking-[0.5px]"
        >
          1. 5-HOUR USAGE SMOOTHING
        </h3>
        <p class="text-retro-card-body leading-[1.35] text-[#999]">
          Monitors active prompt volumes in rolling 5-hour slots. If a user exceeds their fair
          share, ccshare automatically queues requests to guarantee equal access.
        </p>
      </div>

      <div class="border-retro-border bg-retro-card flex flex-col gap-2 border-2 px-5 py-4">
        <h3
          class="font-press text-retro-card-title text-retro-feat-2 leading-[1.4] tracking-[0.5px]"
        >
          2. WEEKLY QUOTA CAPPING
        </h3>
        <p class="text-retro-card-body leading-[1.35] text-[#999]">
          Tracks total tokens spent throughout the week, helping teams stay within boundaries and
          avoid subscription suspensions or service lockouts.
        </p>
      </div>

      <div class="border-retro-border bg-retro-card flex flex-col gap-2 border-2 px-5 py-4">
        <h3
          class="font-press text-retro-card-title text-retro-feat-3 leading-[1.4] tracking-[0.5px]"
        >
          3. TIERED CAPACITY PROXYING
        </h3>
        <p class="text-retro-card-body leading-[1.35] text-[#999]">
          Optimizes throughput allocations depending on whether you share a Pro ($20/mo), Team
          ($100/mo), or custom Enterprise ($200/mo) tier subscription.
        </p>
      </div>
    </div>
  </main>
</Layout>

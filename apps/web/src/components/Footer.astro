---
import FooterStripes from "./FooterStripes";

interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<div class="mx-auto mt-auto flex w-full max-w-[1200px] flex-col">
  <FooterStripes client:load className={className} />

  <footer
    class="font-vt text-retro-footer z-[80] flex items-center justify-between px-8 py-4 max-[640px]:px-4 max-[480px]:flex-col max-[480px]:gap-2"
  >
    <div
      class="retro-reveal flex items-center gap-[10px]"
      data-stripes="2"
      data-color="bg"
      data-delay="1.6"
    >
      <img
        src="/ccshare.webp"
        alt="CCShare"
        class="h-6 w-auto translate-y-0.5 select-none [image-rendering:pixelated]"
      />
      <span class="select-none tracking-[1px] opacity-40">ccshare © 2026</span>
    </div>
    <nav>
      <ul class="flex gap-[22px]">
        <li class="retro-reveal" data-stripes="2" data-color="bg" data-delay="1.7">
          <a
            href="/docs/legal/privacy"
            class="text-retro-fg hover:text-retro-orange no-underline opacity-60 transition-colors hover:opacity-100"
          >
            PRIVACY POLICY
          </a>
        </li>
        <li class="retro-reveal" data-stripes="2" data-color="bg" data-delay="1.8">
          <a
            href="/docs/legal/terms"
            class="text-retro-fg hover:text-retro-orange no-underline opacity-60 transition-colors hover:opacity-100"
          >
            TERMS OF USE
          </a>
        </li>
        <li class="retro-reveal" data-stripes="2" data-color="bg" data-delay="1.9">
          <a
            href="/docs/legal/dmca"
            class="text-retro-fg hover:text-retro-orange no-underline opacity-60 transition-colors hover:opacity-100"
          >
            DMCA
          </a>
        </li>
      </ul>
    </nav>
  </footer>
</div>

---
import ClawdUser from "./ClawdUser.astro";

const getDots = (x1: number, y1: number, x2: number, y2: number, numDots = 4) => {
  return Array.from({ length: numDots }).map((_, i) => {
    const progress = (i + 1) / (numDots + 1);
    return {
      x: x1 + (x2 - x1) * progress,
      y: y1 + (y2 - y1) * progress,
    };
  });
};

const lines = [
  { id: 1, start: [190, 80], target: [120, 60] },
  { id: 3, start: [180, 170], target: [100, 170] },
  { id: 5, start: [190, 270], target: [110, 280] },
  { id: 2, start: [450, 80], target: [510, 60] },
  { id: 4, start: [460, 170], target: [540, 170] },
  { id: 6, start: [450, 260], target: [520, 280] },
];
---

<div
  class="relative flex h-[340px] w-full items-center justify-center overflow-visible max-[640px]:h-[200px] max-[480px]:h-[170px]"
>
  <div
    class="relative h-[340px] w-[640px] shrink-0 origin-center scale-90 overflow-visible max-[640px]:scale-[0.55] max-[480px]:scale-[0.45] max-[380px]:scale-[0.4]"
  >
    <!-- DOTS -->
    <svg class="pointer-events-none absolute inset-0 z-10 h-full w-full" viewBox="0 0 640 340">
      {
        lines.map((line) => (
          <g class={`clawd-line-group-${line.id}`}>
            {getDots(line.start[0], line.start[1], line.target[0], line.target[1]).map((dot, i) => (
              <rect
                x={dot.x - 3}
                y={dot.y - 3}
                width="6"
                height="6"
                fill="var(--color-retro-fg)"
                class={`clawd-dot-${line.id}`}
              />
            ))}
          </g>
        ))
      }
    </svg>

    <!-- MONITOR -->
    <div class="absolute left-[180px] top-10 w-[280px]">
      <div class="clawd-monitor opacity-0">
        <img
          src="/desktop.webp"
          alt="monitor"
          class="block w-full opacity-90 [image-rendering:pixelated]"
        />
      </div>
      <div
        class="clawd-logo absolute left-[58px] top-[63px] flex h-[38%] w-[38%] items-center justify-center overflow-hidden opacity-0"
      >
        <img
          src="/claude.webp"
          alt="Claude"
          class="animate-spin-slow h-auto w-full opacity-90 [image-rendering:pixelated]"
        />
      </div>
    </div>

    <!-- L1 -->
    <ClawdUser
      name="user_1"
      userNum={1}
      class="clawd-1 left-[30px] top-[-5px] opacity-0"
      animationClass="animate-float-a"
    />

    <!-- L2 -->
    <ClawdUser
      name="user_3"
      userNum={3}
      class="clawd-3 left-[0px] top-[120px] opacity-0"
      animationClass="animate-float-b"
    />

    <!-- L3 -->
    <ClawdUser
      name="user_5"
      userNum={5}
      class="clawd-5 left-[20px] top-[240px] opacity-0"
      animationClass="animate-float-a-slow"
    />

    <!-- R1 -->
    <ClawdUser
      name="user_2"
      userNum={2}
      class="clawd-2 left-[510px] top-[0px] opacity-0"
      animationClass="animate-float-b-fast"
      flip
    />

    <!-- R2 -->
    <ClawdUser
      name="user_4"
      userNum={4}
      class="clawd-4 left-[540px] top-[120px] opacity-0"
      animationClass="animate-float-a-mid"
      flip
    />

    <!-- R3 -->
    <ClawdUser
      name="user_6"
      userNum={6}
      class="clawd-6 left-[510px] top-[230px] opacity-0"
      animationClass="animate-float-b-mid"
      flip
    />
  </div>
</div>

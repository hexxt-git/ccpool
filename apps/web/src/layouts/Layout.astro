---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  url?: string;
  image?: string;
}

const {
  title = "ccpool | a cli to equally share claude subscriptions",
  description = "a cli to equally share claude subscriptions",
  url = "https://github.com/hexxt-git/ccpool",
  image = "/ccpool-large.jpg",
} = Astro.props;

const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : new URL(Astro.url.pathname, url);
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Global Metadata -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/webp" href="/ccpool.webp" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />
    <ClientRouter />

    <!--
      No-JS fallback: several elements are server-rendered in their pre-animation
      hidden state (feature cards start at opacity:0; the Visualization island and
      footer stripes are rendered by framer-motion at opacity:0 / clip-path /
      scaleX(0) awaiting hydration). With scripts disabled the reveal never runs,
      so force that content to its final, static state. `.retro-reveal` text needs
      nothing — JS only layers stripe overlays on top of already-visible content.
    -->
    <noscript>
      <style>
        .feature-reveal {
          opacity: 1 !important;
        }
        .viz-reveal {
          opacity: 1 !important;
          clip-path: none !important;
        }
        .viz-mask,
        .viz-dots {
          display: none !important;
        }
        .footer-stripe {
          transform: none !important;
        }
      </style>
    </noscript>
  </head>
  <body class="bg-retro-bg text-retro-fg font-vt flex min-h-screen flex-col overflow-x-hidden">
    <div transition:persist="header" class="bg-retro-bg sticky top-0 z-50 w-full">
      <Header />
    </div>
    <slot />
    <div transition:persist="footer">
      <Footer />
    </div>

    <script>
      import { animate, inView, stagger } from "motion";

      const initReveals = () => {
        const colors = [
          "var(--color-retro-stripe-1)",
          "var(--color-retro-stripe-2)",
          "var(--color-retro-stripe-3)",
          "var(--color-retro-stripe-4)",
        ];

        document.querySelectorAll(".retro-reveal:not(.initialized)").forEach((el) => {
          el.classList.add("initialized");
          const htmlEl = el as HTMLElement;

          if (getComputedStyle(htmlEl).position === "static") {
            htmlEl.style.position = "relative";
          }

          const isH1 = htmlEl.tagName.toLowerCase() === "h1";
          const stripesCount = isH1 ? parseInt(htmlEl.getAttribute("data-stripes") || "4") : 1;

          const delayAttr = htmlEl.getAttribute("data-delay") || "0.1";
          const direction = htmlEl.getAttribute("data-direction") || "alternate";
          const colorMode = htmlEl.getAttribute("data-color") || "bg";

          let defaultBg = "var(--color-retro-bg)";
          let currentEl: HTMLElement | null = htmlEl;
          while (currentEl) {
            const bg = window.getComputedStyle(currentEl).backgroundColor;
            if (bg !== "rgba(0, 0, 0, 0)" && bg !== "transparent") {
              defaultBg = bg;
              break;
            }
            currentEl = currentEl.parentElement;
          }

          const overlay = document.createElement("div");
          overlay.className = "absolute inset-0 z-10 flex flex-col pointer-events-none";
          // to fix any 1px gap issues with absolute positioning
          overlay.style.margin = "-1px";

          const stripes: HTMLDivElement[] = [];
          for (let i = 0; i < stripesCount; i++) {
            const stripe = document.createElement("div");
            stripe.className = "w-full flex-1";

            if (colorMode === "stripes") {
              stripe.style.backgroundColor = colors[i % colors.length];
            } else {
              stripe.style.backgroundColor = defaultBg;
            }

            if (direction === "down" || direction === "up") {
              stripe.style.transformOrigin = direction === "down" ? "bottom" : "top";
              stripe.style.transform = "scaleY(1)";
            } else {
              let origin = "left";
              if (direction === "right") {
                origin = "right";
              } else if (direction === "alternate") {
                origin = i % 2 === 0 ? "left" : "right";
              }
              stripe.style.transformOrigin = origin;
              stripe.style.transform = "scaleX(1)";
            }

            overlay.appendChild(stripe);
            stripes.push(stripe);
          }

          htmlEl.appendChild(overlay);

          const isVertical = direction === "down" || direction === "up";

          inView(
            htmlEl,
            () => {
              const hasLoaded = performance.now() > 2000;
              const delay = hasLoaded ? 0 : parseFloat(delayAttr);
              animate(stripes, isVertical ? { scaleY: 0 } : { scaleX: 0 }, {
                delay: stagger(0.15, { startDelay: delay }),
                duration: 0.46,
                ease: "circOut",
              });
            },
            { amount: 0.1 }
          );
        });

        const featureCards = document.querySelectorAll(".feature-reveal");
        if (featureCards.length > 0) {
          inView(
            featureCards[0],
            () => {
              const hasLoaded = performance.now() > 2000;
              const cardDelay = hasLoaded ? 0 : 1.15;
              animate(
                featureCards,
                { clipPath: ["inset(0 0 100% 0)", "inset(0 0 0 0)"], opacity: [1, 1] },
                { delay: stagger(0.15, { startDelay: cardDelay }), duration: 0.4, ease: "linear" }
              );
            },
            { amount: 0.1 }
          );
        }
      };

      // astro:page-load fires on initial load AND on view transitions,
      // so a single listener covers both cases without double-firing.
      document.addEventListener("astro:page-load", initReveals);
    </script>

  </body>
</html>

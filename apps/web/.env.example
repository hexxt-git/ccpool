# PostHog analytics — these are PUBLIC (client-side) values, inlined at BUILD time.
# On Vercel, set them as Build-time Environment Variables (not runtime).

# Required. Your PostHog project API key (safe to expose; it's client-side).
PUBLIC_POSTHOG_PROJECT_TOKEN=phc_zASFaKWak9Q63F8Fz3SeAsNDgTYX6mKcdjfbX2aHnXkk

# Optional. Defaults to https://us.i.posthog.com. Set to the EU host
# (https://eu.i.posthog.com) if your project is in the EU region.
#
# For a PostHog managed reverse proxy, set this to your proxy subdomain
# (e.g. https://ccpool-u.hexxt.dev). ui_host stays pinned to PostHog in
# posthog.astro so toolbar/session-replay links still resolve.
# PUBLIC_POSTHOG_HOST=
